    "groq": "^3.68.3"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^5.0.1",
    "@types/react": "^18.0.25",
    "eslint": "^9.17.0",
    "prettier": "^3.0.2",
    "typescript": "^5.1.6",
    "concurrently": "^9.1.0"
  },
  "peerDependencies": {
    "@sanity/client": "^6.24.1"
  }
