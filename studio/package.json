{
  "name": "@haakonsvane/site-studio",
  "private": true,
  "version": "0.0.1",
  "main": "package.json",
  "license": "UNLICENSED",
  "exports": {
    "studio": {
      "import": "./dist/index.html"
    },
    "types": {
      "import": "./dist/types/index.d.ts"
    }
  },
  "type": "module",
  "scripts": {
