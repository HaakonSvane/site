{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build", "generate-schema"],
            "outputs": ["build/**", "dist/**"]
        },
        "generate-schema": {
            "dependsOn": ["^generate-schema"],
            "outputs": ["app/sanity/sanity-types.ts", "schema.json"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck"]
        },
        "dev": {
            "persistent": true,
            "cache": false
        }
    }
}
